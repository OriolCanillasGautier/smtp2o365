# =============================================================================
# SMTP Relay — Configuration
# Copy this file to ".env" and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Relay listen settings
# -----------------------------------------------------------------------------

# IP address to bind on.  0.0.0.0 = all interfaces (recommended inside Docker)
LISTEN_HOST=0.0.0.0

# TCP port to listen on.
#   • 25  — standard SMTP. Requires admin/root on Linux. Usually fine on Windows.
#   • 2525 — unprivileged alternative if port 25 is blocked or firewalled.
LISTEN_PORT=25

# -----------------------------------------------------------------------------
# Delivery mode
# -----------------------------------------------------------------------------
#
# smtp_auth    — Authenticate to smtp.office365.com:587 with user + password.
#                Requires SMTP AUTH to be enabled on the mailbox (see README).
#                Use this when App Passwords are available in the tenant.
#
# oauth2_graph — Acquire a token via Azure AD Client Credentials and call the
#                Microsoft Graph API /sendMail endpoint.
#                Use this when SMTP AUTH is disabled or App Passwords are not
#                available (e.g. Conditional Access blocks them).
#                Requires an Entra app registration with Mail.Send permission.
#
AUTH_MODE=oauth2_graph

# -----------------------------------------------------------------------------
# Office 365 sending account
# -----------------------------------------------------------------------------

# The mailbox that will appear as sender and that the relay authenticates as.
# In oauth2_graph mode the app registration must have Mail.Send permission
# and this mailbox must exist in the same tenant.
O365_USERNAME=relay@yourdomain.com

# -----------------------------------------------------------------------------
# smtp_auth mode — credentials
# (Only used when AUTH_MODE=smtp_auth)
# -----------------------------------------------------------------------------

O365_SMTP_HOST=smtp.office365.com
O365_SMTP_PORT=587

# Password for the O365 account.
# • No MFA: use the regular account password.
# • Per-user MFA with App Passwords enabled: paste the App Password here.
#   App Passwords are generated at https://mysignins.microsoft.com/security-info
#   They can be any length and contain letters, digits and special characters.
# • Conditional Access / Security Defaults: App Passwords are typically
#   unavailable — use AUTH_MODE=oauth2_graph instead.
O365_PASSWORD=your-password-or-app-password-here

# -----------------------------------------------------------------------------
# oauth2_graph mode — Azure app registration
# (Only used when AUTH_MODE=oauth2_graph)
# -----------------------------------------------------------------------------
#
# How to set up the app registration in Microsoft Entra admin center:
#   1. Go to https://entra.microsoft.com → App registrations → New registration.
#      Name it (e.g. "smtp-relay"), leave redirect URI empty, register.
#   2. Note the "Application (client) ID" and "Directory (tenant) ID".
#   3. Certificates & secrets → New client secret.
#      Give it a description and expiry, then copy the VALUE (shown only once).
#      The secret is a long string with letters, digits and special characters.
#   4. API permissions → Add a permission → Microsoft Graph → Application permissions
#      → Mail.Send → Add permissions → Grant admin consent.
#

# Directory (tenant) ID from the app registration overview page.
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Application (client) ID from the app registration overview page.
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret VALUE (not the secret ID) from Certificates & secrets.
# It looks like: YG4~aBcDeFgH1234567890-_xYzABCD (length and chars vary).
AZURE_CLIENT_SECRET=your-client-secret-value-here

# -----------------------------------------------------------------------------
# Forwarding
# -----------------------------------------------------------------------------

# All accepted messages are re-delivered to this single address.
FORWARD_TO=destination@yourdomain.com

# When true (strongly recommended), the From header is rewritten to O365_USERNAME
# so the submission is accepted without explicit "Send As" permissions.
# The original sender is preserved in Reply-To and X-Original-From headers.
REWRITE_FROM=true

# -----------------------------------------------------------------------------
# Anti-relay protection  (prevents this server from being used as an open relay)
# -----------------------------------------------------------------------------

# Comma-separated list of exact sender addresses that are permitted.
ALLOWED_SENDERS=1@domain.local,2@domain.local

# Comma-separated list of sender domains.  Any address @domain is accepted.
# Combined with ALLOWED_SENDERS (either list matching is enough).
ALLOWED_SENDER_DOMAINS=domain.local

# Comma-separated list of client IP addresses allowed to connect.
# Add the IPs of your SQL Server, ERP, or any other legacy service here.
# Leave EMPTY to disable IP filtering (only do this on a fully isolated network).
ALLOWED_CLIENT_IPS=127.0.0.1,::1,192.168.1.10,192.168.1.25

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
