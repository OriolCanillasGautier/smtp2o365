# =============================================================================
# SMTP Relay — Configuration
# Copy this file to ".env" and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# Relay listen settings
# -----------------------------------------------------------------------------

# IP address to bind on.  0.0.0.0 = all interfaces (recommended inside Docker)
LISTEN_HOST=0.0.0.0

# TCP port to listen on.
#   • 25  — standard SMTP. Requires admin/root on Linux. Usually fine on Windows.
#   • 2525 — unprivileged alternative if port 25 is blocked or firewalled.
LISTEN_PORT=25

# The mailbox that will appear as sender and that the relay authenticates as.
O365_USERNAME=relay@yourdomain.com

# Delivery mode: choose ONE
#   smtp_auth    — Use O365_PASSWORD (app password or regular password)
#   oauth2_graph — Use AZURE_* credentials (app registration client secret)
AUTH_MODE=oauth2_graph

# All accepted messages are re-delivered to this address.
# Leave empty to preserve the original recipients (To/Cc headers from incoming email).
#   • If set: all emails are redirected to this single address.
#   • If empty: each email is delivered to its original recipients.
# FORWARD_TO=destination@yourdomain.com

# When true (strongly recommended), the From header is rewritten to O365_USERNAME
# so the submission is accepted without explicit "Send As" permissions.
# The original sender is preserved in Reply-To and X-Original-From headers.
REWRITE_FROM=true

# =============================================================================
# smtp_auth mode settings
# (Only needed if AUTH_MODE=smtp_auth)
# =============================================================================

# SMTP credentials for the O365 account.
#   • No MFA: use the regular account password
#   • Per-user MFA with App Passwords: paste the App Password (any length/format)
#   • Conditional Access: App Passwords may be unavailable — use oauth2_graph instead
# O365_PASSWORD=your-password-or-app-password-here

O365_SMTP_HOST=smtp.office365.com
O365_SMTP_PORT=587

# =============================================================================
# oauth2_graph mode settings
# (Only needed if AUTH_MODE=oauth2_graph)
# =============================================================================
#
# How to set up in Microsoft Entra admin center:
#   1. App registrations → New registration (name: e.g. "smtp-relay")
#   2. Note the "Application (client) ID" and "Directory (tenant) ID"
#   3. Certificates & secrets → New client secret → copy the VALUE
#   4. API permissions → Add → Microsoft Graph → Application permissions
#      → Mail.Send → Add → Grant admin consent
#

# Directory (tenant) ID
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Application (client) ID
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret VALUE (long string with letters, digits, special characters)
AZURE_CLIENT_SECRET=your-client-secret-value-here

# =============================================================================
# Allow-list settings
# =============================================================================

# Comma-separated list of exact sender addresses that are permitted.
# Example: ALLOWED_SENDERS=sqlreport@company.local,erp@company.local
ALLOWED_SENDERS=sender1@company.local,sender2@company.local

# Comma-separated list of sender domains.
# Combined with ALLOWED_SENDERS (either matching is enough).
# Example: ALLOWED_SENDER_DOMAINS=company.local,erp.internal
ALLOWED_SENDER_DOMAINS=company.local

# Comma-separated list of client IP addresses allowed to connect.
# Add the IPs of your SQL Server, ERP, or any other legacy service here.
# Leave EMPTY to disable IP filtering (only do this on a fully isolated network).
# Example: ALLOWED_CLIENT_IPS=127.0.0.1,::1,10.0.0.50,192.168.1.25
ALLOWED_CLIENT_IPS=127.0.0.1,::1,10.0.0.10

# =============================================================================
# Logging
# =============================================================================

# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
